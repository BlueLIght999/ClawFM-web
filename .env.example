# DeepSeek API Key (required — AI DJ)
# Get yours at: https://platform.deepseek.com
DEEPSEEK_API_KEY=sk-your-deepseek-key-here

# DashScope API Key (required — TTS voice)
# Get yours at: https://dashscope.aliyun.com
DASHSCOPE_API_KEY=sk-your-dashscope-key-here

# Fish Audio API Key (optional — alternative TTS)
FISH_AUDIO_API_KEY=

# Server config (optional)
PORT=3333
NODE_ENV=development

# Weather location override (optional — set if IP geolocation is wrong)
# WEATHER_CITY=Beijing
# WEATHER_LAT=39.9
# WEATHER_LON=116.4
