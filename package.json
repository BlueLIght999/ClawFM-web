    "test:launcher-system": "node server/system-tests/launcher-startup.js"
  },
  "dependencies": {
    "pino": "^10.3.1",
    "pino-http": "^11.0.0",
    "pino-pretty": "^13.1.3",
    "prom-client": "^15.1.3",
    "wait-on": "8.0.5"
  }
}
