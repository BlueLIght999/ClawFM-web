{
  "name": "qclaudio",
  "version": "2.0.0",
  "private": true,
  "type": "module",
  "description": "24/7 AI Radio Station — Qclaudio 88.7",
  "bin": {
    "qclaudio": "./bin/qclaudio.js"
  },
  "scripts": {
    "start": "node bin/qclaudio.js",
